{
  "name": "pubhub-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:billing": "bun --filter pub-billing dev",
    "dev:files": "bun --filter pub-files dev",
    "dev:ops": "bun --filter pub-ops dev",
    "build:billing": "bun --filter pub-billing build",
    "build:files": "bun --filter pub-files build",
    "build:ops": "bun --filter pub-ops build",
    "tauri:billing": "bun --filter pub-billing tauri",
    "tauri:files": "bun --filter pub-files tauri",
    "tauri:ops": "bun --filter pub-ops tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^20.0.0"
  }
}
