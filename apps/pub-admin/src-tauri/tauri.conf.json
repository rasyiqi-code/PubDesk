{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pubhub-admin",
  "version": "0.1.0",
  "identifier": "com.rasyiqi.pubhub-admin",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1426",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PubAdmin",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      },
      "signCommand": "signtool sign /f \"%WIN_CERT_PATH%\" /p \"%WIN_CERT_PASSWORD%\" /fd sha256 /tr http://timestamp.digicert.com /td sha256 %1"
    }
  }
}
